# Trishul SNMP Studio — Configuration

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# SNMP Settings
# ---------------------------------------------------------------------------
SNMP_PORT=1061
SNMP_COMMUNITY=public
TRAP_PORT=1162

# ---------------------------------------------------------------------------
# Application Metadata
# ---------------------------------------------------------------------------
APP_NAME=Trishul-SNMP
APP_VERSION=1.3.0
APP_AUTHOR=Sumit Dhaka
APP_DESCRIPTION=Professional SNMP Simulation Tool

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
SESSION_TIMEOUT=3600

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:8080

# ---------------------------------------------------------------------------
# Auto-Start
# ---------------------------------------------------------------------------
AUTO_START_SIMULATOR=true
AUTO_START_TRAP_RECEIVER=true

# ---------------------------------------------------------------------------
# Remote MIB fetch
# Manual by default. Auto-fetch only runs during MIB upload/reload.
# Sources are checked in order and must contain @mib@ where the module name
# should be substituted. Leave MIB_REMOTE_SOURCES unset to use built-in defaults.
# ---------------------------------------------------------------------------
MIB_AUTO_FETCH=false
# MIB_REMOTE_SOURCES=https://mibs.pysnmp.com/asn1/@mib@,https://mibbrowser.online/mibs/@mib@.mib

# ---------------------------------------------------------------------------
# WebSocket internal UDP side-channel
# Port used by worker subprocesses to notify the main FastAPI process
# of new traps so they can be broadcast to WS clients in real-time.
# This port is loopback-only (127.0.0.1) and never exposed externally.
# ---------------------------------------------------------------------------
WS_INTERNAL_PORT=19876
